{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Team Yap",
  "version": "0.1.0",
  "identifier": "com.teamyap.desktop",
  "build": {
    "frontendDist": "../app"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Team Yap",
        "width": 1180,
        "height": 860,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Business",
    "shortDescription": "A private team message board desktop client.",
    "longDescription": "Team Yap is a small self-hosted team message board with a Tauri desktop client and a FastAPI server.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

